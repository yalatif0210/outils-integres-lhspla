# Base de données — même PostgreSQL que l'app principale, schéma collecte
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/lhspla_staging?schema=collecte

# JWT — DOIT correspondre au JWT_SECRET de lhspla-api (même secret, SSO transparent)
JWT_SECRET=changeme_jwt_secret_min32chars

# Mode auth : sso (lecture du token localStorage de l'app principale) | standalone (mini-login)
AUTH_MODE=sso

# Claim JWT contenant le code entité (entityCode par défaut)
JWT_ENTITY_CLAIM=entityCode

# Port du serveur NestJS
PORT=3001

# URL du front collecte (pour CORS)
COLLECTE_FRONT_URL=http://localhost:4202
