# ── Production environment ────────────────────────────────────────────────────
# Copier en .env.prod et remplir les valeurs sur le serveur

GITHUB_REPOSITORY=owner/repo-name

# PostgreSQL production
PROD_DB_PASSWORD=changeme_prod_db_FORT

# JWT (utiliser des secrets forts : openssl rand -base64 48)
PROD_JWT_SECRET=changeme_jwt_secret_prod_min32chars
PROD_JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_prod

# LLM
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=LHSPLA <noreply@lhspla.ci>

# Infrastructure partagée
PGADMIN_EMAIL=admin@lhspla.ci
PGADMIN_PASSWORD=changeme_pgadmin
N8N_USER=admin
N8N_PASSWORD=changeme_n8n

# Accès services (ports directs — pas de sous-domaines)
# Production  : https://vps.lhspla-ci.org
# Staging     : http://vps.lhspla-ci.org:8080
# Portainer   : http://vps.lhspla-ci.org:9000
# pgAdmin     : http://vps.lhspla-ci.org:5050
# n8n         : http://vps.lhspla-ci.org:5678
