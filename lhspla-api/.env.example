# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/lhspla_bulletin?schema=public"

# JWT
JWT_SECRET="change-this-to-a-very-long-random-secret-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-refresh-secret-also-very-long"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
FRONTEND_URL="http://localhost:4201"

# Email (SMTP)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="your-email@gmail.com"
MAIL_PASS="your-app-password"
MAIL_FROM="LHSPLA Bulletin <noreply@npsp.ci>"

# Deadline alert (cron: every Monday at 8:00 AM)
SUBMISSION_DEADLINE_HOUR=9
