# ── Staging environment ───────────────────────────────────────────────────────
# Copier en .env.staging et remplir les valeurs sur le serveur

GITHUB_REPOSITORY=owner/repo-name

# PostgreSQL staging
STG_DB_PASSWORD=changeme_staging_db

# JWT
STG_JWT_SECRET=changeme_jwt_secret_staging_min32chars
STG_JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_staging

# LLM
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=LHSPLA Staging <noreply@lhspla.ci>
